---
import ProjectTile from '../ui/ProjectTile.astro';
import { categories, categoryByKey, type Project } from '../../lib/projects';

/**
 * ProjectsListing — page header + category filter chips + projects grid.
 * Shared by /progetti and each category page.
 */
interface Props {
  heading: string;
  blurb?: string;
  items: Project[];
  activeSlug?: string | null; // null = "Tutti"
  total: number;
}

const { heading, blurb, items, activeSlug = null, total } = Astro.props;
---

<section class="listing section">
  <div class="container-7xl">
    <header class="listing-head">
      <span class="eyebrow">Portfolio</span>
      <h1 class="h2 listing-title">{heading}</h1>
      {blurb && <p class="listing-blurb">{blurb}</p>}
    </header>

    <nav class="filters" aria-label="Filtra per tipologia">
      <a href="/progetti" class:list={['filter', { 'filter--active': activeSlug === null }]}>
        Tutti <span class="filter-count">{total}</span>
      </a>
      {
        categories.map((c) => (
          <a
            href={`/progetti/${c.slug}`}
            class:list={['filter', { 'filter--active': activeSlug === c.slug }]}
          >
            {c.label}
          </a>
        ))
      }
    </nav>

    <div class="listing-grid">
      {
        items.map((p) => (
          <ProjectTile
            href={`/progetti/${p.slug}`}
            title={p.title}
            eyebrow={[categoryByKey(p.category).label, p.tag].filter(Boolean).join(' · ')}
            meta={p.location}
            image={p.cover}
            imageAlt={p.title}
          />
        ))
      }
    </div>
  </div>
</section>

<style>
  .listing {
    padding-top: clamp(140px, 18vh, 200px);
  }

  .listing-head {
    display: flex;
    flex-direction: column;
    gap: 18px;
    max-width: 52rem;
    margin-bottom: clamp(2rem, 4vw, 3rem);
  }
  .listing-title {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
  }
  .listing-blurb {
    max-width: 48ch;
    font-size: 1.0625rem;
    color: var(--color-concrete);
  }

  .filters {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    padding-bottom: clamp(2rem, 4vw, 3rem);
    margin-bottom: clamp(2rem, 4vw, 3rem);
    border-bottom: 1px solid var(--color-line);
  }
  .filter {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 11px 18px;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-max);
    font-family: var(--font-mono);
    font-size: 0.625rem;
    letter-spacing: var(--tracking-ui-emphasis);
    text-transform: uppercase;
    color: var(--color-ink);
    transition: all var(--duration-fast) var(--ease-editorial);
  }
  .filter:hover {
    letter-spacing: var(--tracking-ui-hover);
    border-color: var(--color-ink);
  }
  .filter--active {
    background: var(--color-ink);
    color: var(--color-paper);
    border-color: var(--color-ink);
  }
  .filter-count {
    font-size: 0.5625rem;
    opacity: 0.6;
  }

  .listing-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  @media (max-width: 900px) {
    .listing-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }
  }
  @media (max-width: 560px) {
    .listing-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
