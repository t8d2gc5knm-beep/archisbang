---
import { ArrowUpRight } from '@lucide/astro';

/**
 * ServiceCard — bordered editorial card for a project typology.
 * Photo strip (grayscale → colour on hover) + index eyebrow + Playfair title
 * + description + underline CTA.
 */
interface Props {
  index: string;
  eyebrow: string;
  title: string;
  description: string;
  href: string;
  image?: string;
  imageAlt?: string;
}

const { index, eyebrow, title, description, href, image, imageAlt = '' } = Astro.props;
---

<a class="service-card" href={href}>
  {
    image && (
      <div class="service-media">
        <img src={image} alt={imageAlt} loading="lazy" decoding="async" />
        <span class="service-icon">
          <slot />
        </span>
        <span class="service-index">{index}</span>
      </div>
    )
  }

  <div class="service-card-inner">
    {
      !image && (
        <div class="service-card-top">
          <span class="service-icon service-icon--static">
            <slot />
          </span>
          <span class="service-index service-index--static">{index}</span>
        </div>
      )
    }

    <div class="service-card-body">
      <span class="label-mono">{eyebrow}</span>
      <h3 class="service-title">{title}</h3>
      <p class="service-desc">{description}</p>
    </div>

    <span class="service-cta">
      <span>Scopri</span>
      <ArrowUpRight size={14} strokeWidth={1.5} />
    </span>
  </div>
</a>

<style>
  .service-card {
    position: relative;
    display: flex;
    flex-direction: column;
    height: 100%;
    overflow: hidden;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-max);
    background: var(--color-paper);
    transition:
      background var(--duration-base) var(--ease-editorial),
      border-color var(--duration-base) var(--ease-editorial),
      transform var(--duration-base) var(--ease-editorial);
  }
  .service-card:hover {
    background: #ffffff;
    border-color: var(--color-ink);
    transform: translateY(-4px);
  }

  /* Photo strip */
  .service-media {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    border-bottom: 1px solid var(--color-line);
  }
  .service-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(100%) contrast(1.02);
    transition:
      transform var(--duration-slow) var(--ease-editorial),
      filter var(--duration-slow) var(--ease-editorial);
  }
  .service-card:hover .service-media img {
    transform: scale(1.04);
    filter: grayscale(0%);
  }
  .service-media .service-icon {
    position: absolute;
    top: 16px;
    left: 16px;
    background: color-mix(in srgb, var(--color-paper) 88%, transparent);
    backdrop-filter: blur(4px);
  }
  .service-media .service-index {
    position: absolute;
    top: 18px;
    right: 18px;
    color: var(--color-paper);
  }

  .service-card-inner {
    display: flex;
    flex-direction: column;
    gap: 24px;
    flex: 1;
    padding: 32px;
  }

  .service-card-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
  }

  .service-icon {
    display: grid;
    place-items: center;
    width: 44px;
    height: 44px;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-max);
    color: var(--color-ink);
    transition:
      color var(--duration-base) var(--ease-editorial),
      border-color var(--duration-base) var(--ease-editorial);
  }
  .service-card:hover .service-icon {
    color: var(--color-rebar);
    border-color: var(--color-rebar);
  }

  .service-index {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: var(--tracking-ui);
    color: var(--color-line);
  }
  .service-index--static {
    color: var(--color-line);
  }

  .service-card-body {
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin-top: auto;
  }
  .service-title {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 2.4vw, 1.875rem);
    font-weight: 400;
    line-height: 1.1;
    color: var(--color-ink);
  }
  .service-desc {
    font-family: var(--font-text);
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--color-concrete);
  }

  .service-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 0.625rem;
    letter-spacing: var(--tracking-ui-emphasis);
    text-transform: uppercase;
    color: var(--color-ink);
    transition:
      gap var(--duration-fast) var(--ease-editorial),
      color var(--duration-fast) var(--ease-editorial);
  }
  .service-card:hover .service-cta {
    gap: 14px;
    color: var(--color-rebar);
  }
</style>
