---
import BaseLayout from '../layouts/BaseLayout.astro';
import PulseDot from '../components/ui/PulseDot.astro';
import Button from '../components/ui/Button.astro';
import Stats from '../components/sections/Stats.astro';
import Services from '../components/sections/Services.astro';
import FeaturedProjects from '../components/sections/FeaturedProjects.astro';
---

<BaseLayout>
  <section class="hero">
    <div class="hero-media" aria-hidden="true">
      <img src="/images/hero.jpg" alt="" fetchpriority="high" />
    </div>

    <div class="container-7xl hero-inner">
      <div class="pulse-badge">
        <PulseDot />
        <span class="label-mono">Studio di Architettura · Torino · dal 2008</span>
      </div>

      <h1 class="h1-hero">
        Architetture<br />
        <em>per il</em> territorio<br />
        scuole, riqualificazioni,<br />
        <em>spazi che</em> generano comunità
      </h1>

      <div class="hero-cta">
        <Button href="/contatti" label="Inizia un progetto" />
      </div>
    </div>
  </section>

  <div id="numeri"></div>
  <Stats />
  <Services />
  <FeaturedProjects />
</BaseLayout>

<style>
  /* Hero fills exactly one screen — fully visible without scrolling.
     All vertical sizing is viewport-height responsive so it never overflows. */
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: clamp(84px, 11vh, 124px) 0 clamp(28px, 6vh, 80px);
  }

  /* Project photo behind the hero, under a paper veil so ink text stays crisp. */
  .hero-media {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }
  .hero-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(100%) contrast(1.04);
  }
  .hero-media::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(
        130% 90% at 50% 42%,
        color-mix(in srgb, var(--color-paper) 86%, transparent) 0%,
        color-mix(in srgb, var(--color-paper) 72%, transparent) 55%,
        color-mix(in srgb, var(--color-paper) 60%, transparent) 100%
      ),
      linear-gradient(
        180deg,
        var(--color-paper) 0%,
        transparent 22% 78%,
        var(--color-paper) 100%
      );
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* Responsive H1: bounded by BOTH viewport height (so it fits one screen)
     and width (so long words never overflow narrow screens). */
  .hero :global(.h1-hero) {
    font-size: clamp(1.75rem, min(8.4vh, 9.2vw), 5rem);
  }

  .pulse-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 14px;
    max-width: min(100%, 540px);
    margin-bottom: clamp(16px, 3.4vh, 48px);
    padding: 11px 22px;
    border: 1px solid color-mix(in srgb, var(--color-ink) 24%, transparent);
    border-radius: var(--radius-max);
    background: color-mix(in srgb, #ffffff 72%, var(--color-paper));
  }
  .pulse-badge .label-mono {
    text-align: center;
    color: var(--color-ink);
    font-size: 0.6875rem;
    letter-spacing: 0.26em;
  }
  /* Larger dot + pulsing halo ring → more noticeable */
  .pulse-badge :global(.pulse-dot) {
    position: relative;
    width: 8px;
    height: 8px;
  }
  .pulse-badge :global(.pulse-dot)::after {
    content: '';
    position: absolute;
    inset: -5px;
    border-radius: 50%;
    border: 1px solid var(--color-rebar);
    animation: pulse-halo 2.4s var(--ease-editorial) infinite;
  }
  @keyframes pulse-halo {
    0% {
      transform: scale(0.55);
      opacity: 0.85;
    }
    70%,
    100% {
      transform: scale(1.7);
      opacity: 0;
    }
  }
  @media (max-width: 480px) {
    .pulse-badge .label-mono {
      letter-spacing: 0.16em;
    }
  }

  .hero-cta {
    margin-top: clamp(28px, 4.5vh, 56px);
  }

  @media (max-width: 768px) {
    .hero {
      padding-top: 116px;
    }
  }
</style>
