---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectsListing from '../../components/sections/ProjectsListing.astro';
import {
  projects,
  categories,
  categoryByKey,
  projectsByCategory,
  type Project,
  type Category,
} from '../../lib/projects';

export function getStaticPaths() {
  const categoryPaths = categories.map((c) => ({
    params: { slug: c.slug },
    props: { type: 'category' as const, category: c },
  }));
  const projectPaths = projects.map((p, i) => ({
    params: { slug: p.slug },
    props: {
      type: 'project' as const,
      project: p,
      prev: projects[(i - 1 + projects.length) % projects.length],
      next: projects[(i + 1) % projects.length],
    },
  }));
  return [...categoryPaths, ...projectPaths];
}

type Props =
  | { type: 'category'; category: Category }
  | { type: 'project'; project: Project; prev: Project; next: Project };

const props = Astro.props as Props;
---

{
  props.type === 'category' ? (
    <BaseLayout
      title={`${props.category.label} — Archisbang`}
      description={props.category.blurb}
    >
      <ProjectsListing
        heading={props.category.label}
        blurb={props.category.blurb}
        items={projectsByCategory(props.category.key)}
        activeSlug={props.category.slug}
        total={projects.length}
      />
    </BaseLayout>
  ) : (
    <BaseLayout
      title={`${props.project.title} — Archisbang`}
      description={`${props.project.title}: progetto Archisbang${props.project.location ? ' a ' + props.project.location : ''}.`}
    >
      <article class="project section">
        <div class="container-7xl">
          <a href="/progetti" class="cta-link-underline project-back">
            ← Tutti i progetti
          </a>

          <header class="project-head">
            <span class="eyebrow">{categoryByKey(props.project.category).label}</span>
            <h1 class="project-h1">{props.project.title}</h1>
            {(props.project.location || props.project.tag) && (
              <p class="project-meta metadata-mono">
                {[props.project.location, props.project.tag].filter(Boolean).join(' · ')}
              </p>
            )}
          </header>
        </div>

        <div class="container-7xl project-hero-wrap">
          <div class="project-hero">
            <img src={props.project.gallery[0]} alt={props.project.title} fetchpriority="high" />
          </div>
        </div>

        {props.project.gallery.length > 1 && (
          <div class="container-7xl">
            <div class="project-gallery">
              {props.project.gallery.slice(1).map((img, i) => (
                <figure class="project-figure">
                  <img src={img} alt={`${props.project.title} — immagine ${i + 2}`} loading="lazy" decoding="async" />
                </figure>
              ))}
            </div>
          </div>
        )}

        <div class="container-7xl">
          <nav class="project-pager" aria-label="Altri progetti">
            <a href={`/progetti/${props.prev.slug}`} class="pager-link pager-link--prev">
              <span class="pager-dir">← Precedente</span>
              <span class="pager-title">{props.prev.title}</span>
            </a>
            <a href={`/progetti/${props.next.slug}`} class="pager-link pager-link--next">
              <span class="pager-dir">Successivo →</span>
              <span class="pager-title">{props.next.title}</span>
            </a>
          </nav>
        </div>
      </article>
    </BaseLayout>
  )
}

<style>
  .project {
    padding-top: clamp(140px, 18vh, 200px);
  }
  .project-back {
    display: inline-block;
    margin-bottom: clamp(2rem, 4vw, 3rem);
  }
  .project-head {
    display: flex;
    flex-direction: column;
    gap: 16px;
    max-width: 60rem;
  }
  .project-h1 {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    line-height: 1.02;
    letter-spacing: var(--tracking-display);
    color: var(--color-ink);
  }
  .project-meta {
    color: var(--color-concrete);
  }

  .project-hero-wrap {
    margin-block: clamp(2.5rem, 5vw, 4rem);
  }
  .project-hero {
    border: 1px solid var(--color-line);
    border-radius: var(--radius-max);
    overflow: hidden;
    aspect-ratio: 16 / 9;
  }
  .project-hero img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .project-gallery {
    columns: 2;
    column-gap: 24px;
  }
  .project-figure {
    break-inside: avoid;
    margin: 0 0 24px;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-max);
    overflow: hidden;
  }
  .project-figure img {
    display: block;
    width: 100%;
    height: auto;
  }

  .project-pager {
    display: flex;
    justify-content: space-between;
    gap: 24px;
    margin-top: clamp(3rem, 6vw, 5rem);
    padding-top: clamp(2rem, 4vw, 3rem);
    border-top: 1px solid var(--color-line);
  }
  .pager-link {
    display: flex;
    flex-direction: column;
    gap: 8px;
    max-width: 45%;
    transition: color var(--duration-fast) var(--ease-editorial);
  }
  .pager-link--next {
    text-align: right;
    margin-left: auto;
  }
  .pager-dir {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    letter-spacing: var(--tracking-ui-emphasis);
    text-transform: uppercase;
    color: var(--color-concrete);
  }
  .pager-title {
    font-family: var(--font-display);
    font-size: clamp(1.125rem, 2vw, 1.5rem);
    color: var(--color-ink);
    transition: color var(--duration-fast) var(--ease-editorial);
  }
  .pager-link:hover .pager-title {
    color: var(--color-rebar);
  }

  @media (max-width: 720px) {
    .project-gallery {
      columns: 1;
    }
  }
</style>
